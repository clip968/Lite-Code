{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "instructions": [
    ".opencode/instructions/lite-code.md"
  ],
  "agent": {
    "curator": {
      "model": "openai/gpt-5.4"
    },
    "coder": {
      "model": "deepinfra/zai-org/GLM-5"
    },
    "tester": {
      "model": "github-copilot/gemini-3.1-pro-preview"
    },
    "fixer": {
      "model": "deepinfra/zai-org/GLM-5.1"
    },
    "reviewer": {
      "model": "openai/gpt-5.4"
    }
  }
}
