{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPacket",
  "type": "object",
  "required": ["ticket_id", "relevant_files", "key_symbols", "test_files", "wiki_refs", "summary", "confidence"],
  "properties": {
    "ticket_id": { "type": "string" },
    "relevant_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "key_symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "file"],
        "properties": {
          "name": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "test_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "wiki_refs": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
